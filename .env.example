# MongoDB Atlas connection string.
# Keep this secret in Server/.env locally and in Vercel environment variables for deployments.
MONGO_URI=

# Database used by the app.
MONGO_DB_NAME=tracetotrust

# Local Express port. Vercel provides PORT automatically for functions.
PORT=3000

# Password required for /trust-ops and admin API operations.
ADMIN_PASSWORD=

# Stable signing keys for deployments.
# Prefer base64-encoded PEM values in Vercel to avoid newline escaping issues.
SIGNING_PUBLIC_KEY_PEM_B64=
SIGNING_PRIVATE_KEY_PEM_B64=
SIGNING_KEY_CREATED_AT=
